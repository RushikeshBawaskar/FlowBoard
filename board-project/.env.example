APP_NAME=Task Flow API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=5173
APP_RELOAD=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$
LOG_LEVEL=INFO

SQL_ECHO=false
BASE_GAP=1024
MIN_GAP=0.000001

JWT_SECRET_KEY=replace-with-secure-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_CONTAINER_NAME=taskflow-postgres
POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=taskflow_password
POSTGRES_DB=taskflow_db

DATABASE_URL=postgresql+asyncpg://taskflow_user:taskflow_password@127.0.0.1:5432/taskflow_db
